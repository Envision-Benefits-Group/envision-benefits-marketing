# Environment settings
ENVIRONMENT=DEV # Set the environment (DEV, STAGING, PROD)

# Mailpit
USE_MAILPIT=true # Use Mailpit for email testing or false for production

# Application credentials
APP_EMAIL=your-email@example.com # Email address for the application
ADMIN_EMAIL=admin@example.com # Email address to receive admin notifications (feedback, etc.)
SMTP_USERNAME=xyz # AWS SES username
SMTP_PASSWORD=abc # AWS SES password

# Authentication token settings
ACCESS_TOKEN_EXPIRE_MINUTES=120 # Expiration time for access tokens in minutes
REFRESH_TOKEN_EXPIRE_DAYS=7 # Expiration time for refresh tokens in days

# PostgreSQL database settings
POSTGRES_DB=postgres # Name of your PostgreSQL database
POSTGRES_USER=postgres # Username for your PostgreSQL database
POSTGRES_PASSWORD=postgres # Password for your PostgreSQL database
POSTGRES_HOST=db # Hostname for your PostgreSQL server (usually the service name in Docker)
POSTGRES_PORT=5432 # Port number for your PostgreSQL server

# Full Database URL with asyncpg driver for application connection
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Alembic database URL using psycopg2 (synchronous) for database migrations
ALEMBIC_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Security configuration
secret=your-secret-key # Secret key for signing tokens or cookies
algorithm=HS256 # Algorithm used for cryptographic operations (e.g., JWT)

# Superuser (admin) account settings
SUPERUSER_EMAIL=admin@example.com # Email for the superuser account
SUPERUSER_PASSWORD=your-superuser-password # Password for the superuser account

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:8000 # Backend API URL
FRONTEND_URL=http://localhost:3000 # Frontend URL for the application

# Stripe payment settings
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key # Stripe publishable key for test mode
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key # Stripe secret key for test mode
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret # Secret for Stripe webhooks
SUCCESS_URL=http://localhost:3000/success # URL to redirect to after successful payment
CANCEL_URL=http://localhost:3000/cancel # URL to redirect to if payment is canceled
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key # Public Stripe key for frontend use

# AWS settings
AWS_ACCESS_KEY_ID=your-aws-access-key-id # AWS access key ID
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key # AWS secret access key
S3_BUCKET_NAME=your-s3-bucket-name # Name of the S3 bucket for file storage
AWS_REGION=your-aws-region # AWS region where the S3 bucket is located

# QDRANT Vector Database settings
QDRANT_URL=http://qdrant:6333 # Qdrant database URL

# TEI (Text Embeddings Inference) ENV VARIABLES
TEI_API_KEY=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 # API key for TEI service
MODEL_ID=BAAI/bge-small-en-v1.5 # Specify the model to use
MAX_CLIENT_BATCH_SIZE=200 # Maximum client batch size
DTYPE=float32 # Data type for inference
HF_API_TOKEN=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 # Hugging Face API token
USE_FLASH_ATTENTION=True # Enable flash attention
AUTO_TRUNCATE=true # Enable auto truncate
CORS_ALLOW_ORIGIN="*" # CORS allow origin
PORT=3000 # TEI service port
TEI_URL=http://tei_cpu:3000 # TEI service URL (internal Docker network)

# GHL
GHL_API_KEY=your-ghl-api-key # API key for GHL (Go High Level)